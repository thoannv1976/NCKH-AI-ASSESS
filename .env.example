# ===== AI-Assess — mẫu biến môi trường =====
# Sao chép thành .env và chỉnh cho phù hợp. Trên Cloud Run, các biến này được
# truyền qua --set-env-vars / --set-secrets (xem deploy/deploy.sh).

# Chế độ chạy: local (SQLite + tệp cục bộ) hoặc gcp (Firestore + Cloud Storage)
APP_MODE=local

# Định danh trường (hiển thị trên giao diện, email, tài liệu, prompt chấm)
ORG_NAME=Trường Đại học Đại Nam
ORG_SHORT=DNU
PROGRAM_YEAR=2026
# APP_TITLE=        # mặc định = "<ORG_SHORT> AI-Assess"; đặt nếu muốn tên khác

# Khóa Claude API (có thể bỏ trống và nạp trong app tại "Cấu hình AI")
ANTHROPIC_API_KEY=
GRADING_MODEL=claude-opus-4-8

# Bootstrap tài khoản quản trị đầu tiên
ADMIN_EMAILS=admin@example.edu.vn
ADMIN_PASSWORD=Admin@2026
DEFAULT_PASSWORD=Edu@2026

# Bảo mật & lập lịch
SECRET_KEY=doi-thanh-chuoi-ngau-nhien-dai
CRON_TOKEN=doi-thanh-chuoi-ngau-nhien

# Mốc thời gian (admin sửa được trong app)
DEADLINE=2026-06-30T17:00:00+07:00
OPEN_AT=2026-06-25T00:00:00+07:00

# ---- Chỉ dùng khi APP_MODE=gcp ----
GOOGLE_CLOUD_PROJECT=
GCS_BUCKET=
# Gửi email kết quả/nhắc hạn (tùy chọn; bỏ trống = chỉ ghi log trong app).
# Dùng Gmail/Google Workspace: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587,
# SMTP_USER=địa-chỉ-gửi, SMTP_PASSWORD=App-Password-16-ký-tự (bật 2 bước rồi tạo).
# Nên dùng email Workspace theo tên miền trường (giới hạn 2.000 thư/ngày, ít vào spam).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=

# ---- Chế độ demo ----
# SEED_DEMO=1   # tự tạo tài khoản + hồ sơ demo khi khởi động (chỉ dùng để thử)
